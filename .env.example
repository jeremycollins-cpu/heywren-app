# ============================================================================
# HeyWren Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
# ============================================================================

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------

# Base URL of the application (used for OAuth redirects, Stripe callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------

# Supabase project URL (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — server-side only, never expose to the client
# (Settings > API > service_role secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------------------------
# Anthropic / AI
# ----------------------------------------------------------------------------

# Anthropic API key for commitment detection and draft generation
ANTHROPIC_API_KEY=sk-ant-api03-...

# ----------------------------------------------------------------------------
# Slack
# ----------------------------------------------------------------------------

# Slack App OAuth client ID (api.slack.com > Your App > Basic Information)
SLACK_CLIENT_ID=1234567890.1234567890
NEXT_PUBLIC_SLACK_CLIENT_ID=1234567890.1234567890

# Slack App OAuth client secret
SLACK_CLIENT_SECRET=abcdef1234567890abcdef1234567890

# Slack Bot User OAuth Token (xoxb-)
SLACK_BOT_TOKEN=your-slack-bot-token

# Slack signing secret for verifying incoming webhook requests
SLACK_SIGNING_SECRET=abcdef1234567890abcdef1234567890

# ----------------------------------------------------------------------------
# Stripe
# ----------------------------------------------------------------------------

# Stripe publishable key (client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe secret key (server-side)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook endpoint secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for subscription plans
# Monthly prices
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_TEAM_MONTHLY_PRICE_ID=price_...
# Annual prices (billed yearly)
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_TEAM_ANNUAL_PRICE_ID=price_...

# ----------------------------------------------------------------------------
# Azure AD / Outlook
# ----------------------------------------------------------------------------

# Azure AD application (client) ID for Outlook integration
AZURE_AD_CLIENT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Azure AD client secret
AZURE_AD_CLIENT_SECRET=your-azure-client-secret

# ----------------------------------------------------------------------------
# Inngest (background jobs)
# ----------------------------------------------------------------------------

# Inngest signing key for verifying requests (Settings > Signing Key)
INNGEST_SIGNING_KEY=signkey-...

# Inngest event key for sending events (Settings > Event Key)
INNGEST_EVENT_KEY=your-inngest-event-key

# ----------------------------------------------------------------------------
# Resend (transactional email)
# ----------------------------------------------------------------------------

# Resend API key for sending transactional emails (resend.com/api-keys)
RESEND_API_KEY=re_...

# ----------------------------------------------------------------------------
# Nango (integration auth orchestration)
# ----------------------------------------------------------------------------

# Nango secret key for server-side API calls
NANGO_SECRET_KEY=nango-secret-...

# ----------------------------------------------------------------------------
# Zoom (OAuth + Cloud Recording Transcripts)
# ----------------------------------------------------------------------------

# Zoom OAuth App credentials (marketplace.zoom.us > Your App > App Credentials)
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
NEXT_PUBLIC_ZOOM_CLIENT_ID=your-zoom-client-id

# Zoom webhook verification token (for recording.completed events)
ZOOM_WEBHOOK_SECRET_TOKEN=your-zoom-webhook-secret

# ----------------------------------------------------------------------------
# Google (OAuth + Meet Recording Transcripts)
# ----------------------------------------------------------------------------

# Google Cloud OAuth credentials (console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ----------------------------------------------------------------------------
# Chrome Extension
# ----------------------------------------------------------------------------

# Shared secret for extension token generation (generate with: openssl rand -hex 32)
EXTENSION_TOKEN_SECRET=your-extension-token-secret

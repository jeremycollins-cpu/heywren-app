{
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "devCommand": "npm run dev",
  "functions": {
    "app/api/integrations/slack/backfill/route.ts": {
      "maxDuration": 300
    },
    "app/api/integrations/outlook/backfill/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/user-actions/route.ts": {
      "maxDuration": 300
    },
    "app/api/integrations/anthropic-admin/sync/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/anthropic-admin-sync",
      "schedule": "0 6 * * *"
    }
  ]
}
